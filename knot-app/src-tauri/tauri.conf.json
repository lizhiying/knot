{
  "productName": "knot-app",
  "version": "0.1.0",
  "identifier": "com.knot.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:14420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "spotlight",
        "title": "Knot - RAG Spotlight",
        "url": "/",
        "width": 896,
        "height": 153,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": false,
        "center": false,
        "visible": false,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../bin/**/*",
      "../../models/bge-small-zh-v1.5.onnx",
      "../../models/bge-small-zh-v1.5-tokenizer.json",
      "../stopwords.txt"
    ]
  }
}